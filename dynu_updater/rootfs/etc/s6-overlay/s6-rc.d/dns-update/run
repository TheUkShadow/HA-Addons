#!/usr/bin/with-contenv bashio
# vim: ft=bash
# shellcheck shell=bash
# ==============================================================================
# Dynamic DNS Updater
# ==============================================================================

if bashio::config.has_value 'dynu_hostname'; then
	DYNU_HOSTNAME=$(bashio::config 'dynu_hostname' | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')
else
	DYNU_HOSTNAME=""
fi
if bashio::config.has_value 'dynu_update_password'; then
	PASSWORD=$(bashio::config 'dynu_update_password' | xargs)
else
	PASSWORD=""
fi
if bashio::config.true 'verbose'; then
    VERBOSE="true"
else
    VERBOSE="false"
fi

MQTT_CONF="/run/dynu-mqtt.conf"

if [[ -f "$MQTT_CONF" ]]; then
	USE_MQTT=$(jq -r '.mqtt' "$MQTT_CONF")
	MQTT_HOST=$(jq -r '.host' "$MQTT_CONF")
	MQTT_PORT=$(jq -r '.port' "$MQTT_CONF")
	MQTT_USER=$(jq -r '.user' "$MQTT_CONF")
	MQTT_PASSWORD=$(jq -r '.password' "$MQTT_CONF")
else
	bashio::log.error "Dynu DNS Updater - MQTT config not found"
	USE_MQTT="false"
fi
	
mqtt_publish() {
    if [[ "$USE_MQTT" == "true" ]]; then
        local topic="$1"
        local payload="$2"

        if ! mosquitto_pub \
            -h "$MQTT_HOST" \
            -p "$MQTT_PORT" \
            -u "$MQTT_USER" \
            -P "$MQTT_PASSWORD" \
            -t "dynu_updater/$topic" \
            -m "$payload" \
            -r; then

            bashio::log.warning "Dynu DNS Updater - MQTT publish failed: Topic=$topic"
        fi
    fi
}

STATE_FILE="/run/dynu-dns.conf"

if [[ -f "$STATE_FILE" ]]; then
	bashio::log.info "Dynu DNS Updater - Started"
	
	DYNU_IPV6_ENABLED=$(jq -r '.ipv6' "$STATE_FILE")
	readarray -t DOMAIN_ARR < <(jq -r '.domains[]' "$STATE_FILE")
	
	DNS_UPDATE_JSON="/data/dns-update.json"
	
	if [[ -f "$DNS_UPDATE_JSON" ]]; then
		LAST_IPV4=$(jq -r '.ipv4' "$DNS_UPDATE_JSON")
		LAST_IPV6=$(jq -r '.ipv6' "$DNS_UPDATE_JSON")
	else
		LAST_IPV4=""
		LAST_IPV6=""
	fi

	while true; do
		if [[ "$VERBOSE" == "true" ]]; then
			bashio::log.info "Dynu DNS Updater - Checking current IP addresses"
		fi
		
		mqtt_publish "last_ip_check" "$(date -Is)"
		
		# --- Detect IPv4 ---
		IPV4=$(curl -4 -s --fail --max-time 5 https://icanhazip.com | tr -d '[:space:]')

		if [[ -z "$IPV4" ]]; then
			bashio::log.error "Dynu DNS Updater - Unable to confirm current IPv4 address"
		fi
		
		if [[ -n "$IPV4" && ! "$IPV4" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
			bashio::log.error "Dynu DNS Updater - Invalid IPv4 format returned: $IPV4"
			IPV4=""
		fi

		# --- Detect IPv6 only if domain supports it ---
		if [[ "$DYNU_IPV6_ENABLED" == "true" ]]; then
			IPV6=$(curl -6 -s --fail --max-time 5 https://icanhazip.com | tr -d '[:space:]')

			if [[ -z "$IPV6" ]]; then
				bashio::log.error "Dynu DNS Updater - Unable to confirm current IPv6 address"
			fi
			
			if [[ -n "$IPV6" && ! "$IPV6" =~ ^([0-9A-Fa-f]{0,4}:){1,7}[0-9A-Fa-f]{0,4}$ ]]; then
				bashio::log.error "Dynu DNS Updater - invalid IPv6 format returned: $IPV6"
				IPV6=""
			fi
			
		else
			IPV6=""
		fi

		if [[ -n "$IPV4" || -n "$IPV6" ]]; then
			if { [[ -n "$IPV4" && "$IPV4" != "$LAST_IPV4" ]]; } \
			   || { [[ -n "$IPV6" && "$IPV6" != "$LAST_IPV6" ]]; }; then

				bashio::log.info "Dynu DNS Updater - Detected IP change"
				bashio::log.info "Dynu DNS Updater - New IPv4 address = ${IPV4}"
				if [[ "$DYNU_IPV6_ENABLED" == "true" ]]; then
					bashio::log.info "Dynu DNS Updater - New IPv6 address = ${IPV6}"
				fi

				for DOMAIN in "${DOMAIN_ARR[@]}"; do
					if [[ "$DOMAIN" == "$DYNU_HOSTNAME" ]]; then
						bashio::log.info "Dynu DNS Updater - Updating Host ${DOMAIN}"
						COMMAND="https://api.dynu.com/nic/update?hostname=${DYNU_HOSTNAME}&password=${PASSWORD}"
					else
						bashio::log.info "Dynu DNS Updater - Updating Alias ${DOMAIN}"
						ALIAS="${DOMAIN%.$DYNU_HOSTNAME}"
						COMMAND="https://api.dynu.com/nic/update?hostname=${DYNU_HOSTNAME}&alias=${ALIAS}&password=${PASSWORD}"
					fi

					if [[ -n "$IPV4" ]]; then
						COMMAND="${COMMAND}&myip=${IPV4}"
					fi

					if [[ -n "$IPV6" ]]; then
						COMMAND="${COMMAND}&myipv6=${IPV6}"
					fi

					RESPONSE="$(curl -s "${COMMAND}" || echo "No response")"

					bashio::log.info "Dynu DNS Updater - Server responded: $RESPONSE"

				done

				LAST_IPV4="$IPV4"
				LAST_IPV6="$IPV6"
				
				jq -n \
				  --arg ipv4 "$LAST_IPV4" \
				  --arg ipv6 "$LAST_IPV6" \
				  '{ipv4: $ipv4, ipv6: $ipv6}' \
				  > "$DNS_UPDATE_JSON"
				  
				if [[ "$USE_MQTT" == "true" ]]; then
					mqtt_publish "last_ip_update" "$(date -Is)"
					mqtt_publish "current_ipv4" "$IPV4"
					mqtt_publish "current_ipv6" "$IPV6"
				fi
				
			elif [[ "$VERBOSE" == "true" ]]; then
				bashio::log.info "Dynu DNS Updater - No update required"
			fi
			mqtt_publish "wan_connection" "true"
		else
			mqtt_publish "wan_connection" "false"
			bashio::log.error "Dynu DNS Updater - Unable to retrieve current IP address data"
		fi
		
		if [[ ! -f /run/dynu-dns-update.ready ]]; then
			touch /run/dynu-dns-update.ready
		fi

		sleep 60
	done

else
	bashio::log.info "Dynu DNS Updater - Not required"
	touch /run/dynu-dns-update.ready
	sleep infinity
fi
