#!/usr/bin/with-contenv bashio
# vim: ft=bash
# shellcheck shell=bash
# ==============================================================================
# Certificate Manager
# ==============================================================================

while [[ ! -f /run/dynu-dns-update.ready ]]; do
	sleep 1
done

if ! bashio::config.true 'cert.update_cert'; then
	bashio::log.info "Certificate Manager - Not required"
	sleep infinity
fi

DYNU_CONF="/run/dynu-updater.conf"

sleep 1

if [[ ! -f "$DYNU_CONF" ]]; then
	bashio::log.error "Certificate Manager - Dynu API Config not found"
	exit 1
fi

bashio::log.info "Certificate Manager - Started"

DYNU_HOSTNAME=$(bashio::config 'dynu_hostname' | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')
EMAIL=$(bashio::config 'cert.email' | xargs)
KEYFILE=$(bashio::config 'cert.keyfile' | xargs)
CERTFILE=$(bashio::config 'cert.certfile' | xargs)
CAFILE=$(bashio::config 'cert.cafile' | xargs)
CHECK_DAYS=$(bashio::config 'cert.update_cert_days')
DYNU_API_KEY=$(bashio::config 'dynu_api_key' | xargs)

if bashio::config.true 'verbose'; then
    VERBOSE="true"
else
    VERBOSE="false"
fi
if bashio::config.true 'cert.force_renew'; then
    FORCE_RENEW="true"
else
    FORCE_RENEW="false"
fi
if bashio::config.true 'cert.dry_run'; then
    DRY_RUN="true"
else
    DRY_RUN="false"
fi
if bashio::config.true 'mqtt.enabled'; then
    USE_MQTT="true"
else
    USE_MQTT="false"
fi

CERT_DIR=/data/letsencrypt
WORK_DIR=/data/workdir
DNS_MULTI_CREDS=/data/dns-multi.ini
ACME_ARGUMENTS=()
KEY_ARGUMENTS=()
ADDITIONAL_ARGS=()
LOOP_SLEEP=600
POST_CHECK="false"
LAST_CHECK="ok"
PROPAGATION_SECONDS=300

API_DATA=$(< "$DYNU_CONF")
readarray -t DOMAIN_ARR < <(jq -r '.cert_domains[]' <<< "$API_DATA")
if [[ "$USE_MQTT" == "true" ]]; then
	USE_MQTT=$(jq -r '.mqtt.enabled' <<< "$API_DATA")
	MQTT_HOST=$(jq -r '.mqtt.host' <<< "$API_DATA")
	MQTT_PORT=$(jq -r '.mqtt.port' <<< "$API_DATA")
	MQTT_USER=$(jq -r '.mqtt.user' <<< "$API_DATA")
	MQTT_PASSWORD=$(jq -r '.mqtt.password' <<< "$API_DATA")
	readarray -t TLS_FLAGS < <(jq -r '.mqtt.tls_flags[]' <<< "$API_DATA")
else
	USE_MQTT="false"
fi

mqtt_publish() {
    if [[ "$USE_MQTT" == "true" ]]; then
        local topic="$1"
        local payload="$2"

        if ! mosquitto_pub \
            -h "$MQTT_HOST" \
            -p "$MQTT_PORT" \
            -u "$MQTT_USER" \
            -P "$MQTT_PASSWORD" \
            -t "dynu_updater/$topic" \
            -m "$payload" \
            -r \
			"${TLS_FLAGS[@]}"; then

            bashio::log.warning "Certificate Manager - MQTT publish failed: Topic=$topic"
        fi
    fi
}

mkdir -p "${WORK_DIR}"
mkdir -p "${CERT_DIR}"

touch "${DNS_MULTI_CREDS}"
chmod 0600 "${DNS_MULTI_CREDS}"

# Start building the dns-multi credentials file
echo "# generated by letsencrypt app startup script" > "${DNS_MULTI_CREDS}"
echo "dns_multi_provider = dynu" >> "${DNS_MULTI_CREDS}"
echo "DYNU_API_KEY=${DYNU_API_KEY}" >> "${DNS_MULTI_CREDS}"
echo "DYNU_PROPAGATION_TIMEOUT=${PROPAGATION_SECONDS}" >> "${DNS_MULTI_CREDS}"

ACME_ARGUMENTS+=("--authenticator" "dns-multi" "--dns-multi-credentials" "${DNS_MULTI_CREDS}" "--dns-multi-propagation-seconds" "${PROPAGATION_SECONDS}")

# Default Let's Encrypt servers.
ACME_ARGUMENTS+=("--preferred-chain" "ISRG Root X2")

if [[ "$FORCE_RENEW" == "true" ]]; then
	ADDITIONAL_ARGS+=("--force-renewal")
fi

if [[ "$VERBOSE" ==  "true" ]]; then
	ADDITIONAL_ARGS+=("-vvv")
fi

if [[ "$DRY_RUN" == "true" ]]; then
	ADDITIONAL_ARGS+=("--dry-run")
fi

# Set key-type
KEY_ARGUMENTS+=("--key-type" "ecdsa")
KEY_ARGUMENTS+=("--elliptic-curve" "secp256r1")

restart_addons() {
	if bashio::config.has_value 'cert.restart_addons'; then
		RESTARTED=()
		for index in $(bashio::config 'cert.restart_addons|keys'); do
			sleep 1
			RAW_ADDON=$(bashio::config "cert.restart_addons[${index}]")
			ADDON="${RAW_ADDON//-/_}"

			if ! INFO_OUTPUT=$(curl --fail -s \
			  -H "Authorization: Bearer $HASSIO_TOKEN" \
			  http://hassio/addons/${ADDON}/info 2>&1); then
				bashio::log.warning "Certificate Manager - Failed to query state for addon: ${ADDON}"
				continue
			fi

			STATE=$(jq -r '.data.state' <<< "$INFO_OUTPUT")

			if [[ "$STATE" == "started" ]]; then
				if RESTART_OUTPUT=$(curl --fail -s -X POST \
				  -H "Authorization: Bearer $HASSIO_TOKEN" \
				  -H "Content-Type: application/json" \
				  http://hassio/addons/${ADDON}/restart 2>&1); then
					bashio::log.info "Certificate Manager - Restarting add-on ${ADDON}"
					RESTARTED+=("$ADDON")
				else
					bashio::log.error "Certificate Manager - Unable to trigger restart of $ADDON"
				fi
			else
				bashio::log.warning "Certificate Manager - $ADDON is not running (state: $STATE)"
			fi
		done
		
		sleep 10
		
		LOOP_COUNT=0
		
		while (( ${#RESTARTED[@]} > 0 )) && (( LOOP_COUNT < 20 )); do
			for ADDON in "${RESTARTED[@]}"; do
				if INFO_OUTPUT=$(curl --fail -s \
				  -H "Authorization: Bearer $HASSIO_TOKEN" \
				  http://hassio/addons/${ADDON}/info 2>&1); then
					STATE=$(jq -r '.data.state' <<< "$INFO_OUTPUT")
					if [[ "$STATE" == "started" ]]; then
						NEW_LIST=()
						for item in "${RESTARTED[@]}"; do
							[[ "$item" == "$ADDON" ]] || NEW_LIST+=("$item")
						done
						RESTARTED=("${NEW_LIST[@]}")
						bashio::log.info "Certificate Manager - ${ADDON} started"
					fi
				fi
			done
			LOOP_COUNT=$((LOOP_COUNT + 1))
			sleep 1
		done
		
		for ADDON in "${RESTARTED[@]}"; do
			bashio::log.error "Certificate Manager - ${ADDON} failed to restart"
		done
	fi
}

check_connectivity() {
    # Try Dynu (IPv4 or IPv6)
    if curl -4 -s --fail --max-time 5 https://checkip.dynu.com >/dev/null \
	  || curl -6 -s --fail --max-time 5 https://checkip.dynu.com >/dev/null; then
        return 0
    fi

    return 1
}

renew_cert() {
	POST_CHECK="true"
	until check_connectivity; do
        bashio::log.warning "Certificate Manager - Dynu not reachable, delaying certificate renewal"
        sleep 60
    done
	
	set -o pipefail
	
	TMP_OUTPUT=$(mktemp)

	if certbot certonly --non-interactive --keep-until-expiring --expand \
		  --email "$EMAIL" --agree-tos \
		  "${KEY_ARGUMENTS[@]}" \
		  "${ADDITIONAL_ARGS[@]}" \
		  --cert-name "$DYNU_HOSTNAME" "${DOMAIN_ARR[@]/#/-d }" \
		  --config-dir "$CERT_DIR" --work-dir "$WORK_DIR" \
		  --preferred-challenges dns \
		  "${ACME_ARGUMENTS[@]}" \
		  2>&1 | tee "$TMP_OUTPUT"; then
		CERTBOT_EXIT=0
	else
		CERTBOT_EXIT=$?
	fi
	
	# If certbot failed
	if [[ "$CERTBOT_EXIT" -ne 0 ]]; then
		bashio::log.error "Certificate Manager - Certbot failed with code $CERTBOT_EXIT"
		LAST_CHECK="error"
	else
		# If certbot succeeded, check if certificate was updated
		# Load output into a variable
		CERTBOT_OUTPUT=$(< "$TMP_OUTPUT")
		
		if echo "$CERTBOT_OUTPUT" | grep -q "Successfully received certificate"; then
			bashio::log.info "Certificate Manager - New certificate received"
			
			# Get the last modified cert directory and copy the cert and private key to store
			CERT_DIR_LATEST=$(ls -td "$CERT_DIR"/live/*/ 2>/dev/null | head -1)
			if [[ -z "$CERT_DIR_LATEST" ]]; then
				bashio::log.error "Certificate Manager - Unable to locate latest certificate directory"
				return
			fi
			cp "${CERT_DIR_LATEST}privkey.pem" "/ssl/$KEYFILE"
			cp "${CERT_DIR_LATEST}fullchain.pem" "/ssl/$CERTFILE"
			bashio::log.info "Certificate Manager - New certificates copied to /ssl"
			restart_addons
		elif echo "$CERTBOT_OUTPUT" | grep -q "Certificate not yet due for renewal"; then
			bashio::log.info "Certificate Manager - Current certificate is valid"
		elif [[ "$DRY_RUN" == "true" ]] && echo "$CERTBOT_OUTPUT" | grep -q "The dry run was successful"; then	
			bashio::log.info "Certificate Manager - The dry-run was successful"
			restart_addons
		else
			bashio::log.warning "Certificate Manager - Unexpected Certbot output:"
		fi
	fi
}

check_cert_dates() {
    POST_CHECK="false"
	LAST_CHECK="ok"
    CERT_PATH="/data/letsencrypt/live/$DYNU_HOSTNAME/cert.pem"

	if [[ "$FORCE_RENEW" == "true" || "$DRY_RUN" == "true" ]]; then
		bashio::log.info "Certificate Manager - Skipping certificate date check: Force Renew/Dry Run"
        mqtt_publish "last_cert_status" "false"
        renew_cert
    elif [[ -f "$CERT_PATH" ]]; then
		bashio::log.info "Certificate Manager - Checking certificate dates"
		mqtt_publish "last_cert_check" "$(date -Is)"
        if ! CREATED_RAW=$(openssl x509 -in "$CERT_PATH" -noout -startdate 2>/dev/null | cut -d= -f2); then
			CREATED_RAW=""
		fi
		if ! EXPIRY_RAW=$(openssl x509 -in "$CERT_PATH" -noout -enddate 2>/dev/null | cut -d= -f2); then
			EXPIRY_RAW=""
		fi

        # If parsing fails, force renewal
        if [[ -z "$CREATED_RAW" || -z "$EXPIRY_RAW" ]]; then
            bashio::log.warning "Certificate Manager - Unable to parse certificate dates"
            mqtt_publish "last_cert_status" "false"
            renew_cert
        else
            CREATED_ISO=$(date -u -d "$CREATED_RAW" +"%Y-%m-%dT%H:%M:%S+00:00")
            EXPIRY_ISO=$(date -u -d "$EXPIRY_RAW" +"%Y-%m-%dT%H:%M:%S+00:00")

            mqtt_publish "cert_expires" "$EXPIRY_ISO"
            mqtt_publish "last_cert_renewal" "$CREATED_ISO"

            EXPIRY_EPOCH=$(date -d "$EXPIRY_RAW" +%s)
            NOW_EPOCH=$(date +%s)
            MAX_DAYS=$(( NOW_EPOCH + (CHECK_DAYS * 86400) + 60 ))
			
            if (( EXPIRY_EPOCH < NOW_EPOCH )); then
                bashio::log.info "Certificate Manager - Certificate expired, renewing"
				mqtt_publish "last_cert_status" "false"
                renew_cert
            elif (( EXPIRY_EPOCH <= MAX_DAYS )); then
				bashio::log.info "Certificate Manager - Certificate expires in less than $CHECK_DAYS days"
                mqtt_publish "last_cert_status" "true"
                renew_cert
            else
				bashio::log.info "Certificate Manager - Certificate expires $EXPIRY_ISO"
                RENEW_EPOCH=$(( EXPIRY_EPOCH - (CHECK_DAYS * 86400) ))
				LOOP_SLEEP=$(( RENEW_EPOCH - NOW_EPOCH ))
				if (( LOOP_SLEEP < 0 )); then
					LOOP_SLEEP=600
				fi
				mqtt_publish "last_cert_status" "true"
            fi
        fi
    else
        bashio::log.warning "Certificate Manager - Certificate missing/not yet created"
        mqtt_publish "last_cert_status" "false"
        renew_cert
    fi

    # Post-renewal verification
    if [[ "$POST_CHECK" == "true" ]]; then
        if [[ "$LAST_CHECK" == "error" ]]; then
			bashio::log.warning "Certificate Manager - Last renewal failed. Retrying in 10 minutes"
			LOOP_SLEEP=600
		elif [[ -f "$CERT_PATH" ]]; then
			if ! CREATED_RAW=$(openssl x509 -in "$CERT_PATH" -noout -startdate 2>/dev/null | cut -d= -f2); then
				CREATED_RAW=""
			fi
			if ! EXPIRY_RAW=$(openssl x509 -in "$CERT_PATH" -noout -enddate 2>/dev/null | cut -d= -f2); then
				EXPIRY_RAW=""
			fi

            if [[ -n "$CREATED_RAW" && -n "$EXPIRY_RAW" ]]; then
                CREATED_ISO=$(date -u -d "$CREATED_RAW" +"%Y-%m-%dT%H:%M:%S+00:00")
                EXPIRY_ISO=$(date -u -d "$EXPIRY_RAW" +"%Y-%m-%dT%H:%M:%S+00:00")

                mqtt_publish "cert_expires" "$EXPIRY_ISO"
                mqtt_publish "last_cert_renewal" "$CREATED_ISO"

                EXPIRY_EPOCH=$(date -d "$EXPIRY_RAW" +%s)
                NOW_EPOCH=$(date +%s)

                if (( EXPIRY_EPOCH < NOW_EPOCH )); then
                    mqtt_publish "last_cert_status" "false"
					LOOP_SLEEP=600
                else
					RENEW_EPOCH=$(( EXPIRY_EPOCH - (CHECK_DAYS * 86400) ))
					LOOP_SLEEP=$(( RENEW_EPOCH - NOW_EPOCH ))
					if (( LOOP_SLEEP < 0 )); then
						LOOP_SLEEP=600
					fi
                    mqtt_publish "last_cert_status" "true"
                fi
            else
                bashio::log.warning "Certificate Manager - Unable to parse renewed certificate dates."
                mqtt_publish "last_cert_status" "false"
				LOOP_SLEEP=600
            fi
        else
            bashio::log.warning "Certificate Manager - Certificate missing/not created after renewal. Check the logs for more information"
            mqtt_publish "last_cert_status" "false"
			LOOP_SLEEP=600
        fi
    fi
}

while true; do
	check_cert_dates
	
	NEXT_RUN_ISO=$(date -Is -d "@$(( $(date +%s) + LOOP_SLEEP ))")
	bashio::log.info "Certificate Manager - Next renewal check: $NEXT_RUN_ISO"
	mqtt_publish "next_cert_check" "$NEXT_RUN_ISO"
	
	sleep "$LOOP_SLEEP"
done

