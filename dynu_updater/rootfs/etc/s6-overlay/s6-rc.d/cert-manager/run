#!/usr/bin/with-contenv bashio
# vim: ft=bash
# shellcheck shell=bash
# ==============================================================================
# Certificate Manager
# ==============================================================================

LOG_LEVEL=$(bashio::config 'log_level')
bashio::log.level "$LOG_LEVEL"

while [[ ! -f /run/dynu-dns-update.ready ]]; do
	sleep 1
done

if ! bashio::config.true 'cert.update_cert'; then
	bashio::log.info "Certificate Manager - Not required."
	sleep infinity
fi

DYNU_CONF="/run/dynu-updater.conf"

sleep 1

if [[ ! -f "$DYNU_CONF" ]]; then
	bashio::log.error "Certificate Manager - Dynu API Config not found."
	exit 1
fi

bashio::log.info "Certificate Manager - Started."

API_DATA=$(< "$DYNU_CONF")

DYNU_HOSTNAME=$(jq -r '.hostname' <<< "$API_DATA")

DYNU_API_KEY=$(jq -r '.cert.api_key' <<< "$API_DATA")
CHECK_DAYS=$(jq -r '.cert.cert_time' <<< "$API_DATA")
EMAIL=$(jq -r '.cert.email' <<< "$API_DATA")
KEYFILE=$(jq -r '.cert.keyfile' <<< "$API_DATA")
CERTFILE=$(jq -r '.cert.certfile' <<< "$API_DATA")
DRY_RUN=$(jq -r '.cert.dry_run' <<< "$API_DATA")
FORCE_RENEW=$(jq -r '.cert.force_renew' <<< "$API_DATA")

readarray -t DOMAIN_ARR < <(jq -r '.cert.domains[]' <<< "$API_DATA")

USE_MQTT=$(jq -r '.mqtt.enabled' <<< "$API_DATA")

if [[ "$USE_MQTT" == "true" ]]; then
	MQTT_HOST=$(jq -r '.mqtt.host' <<< "$API_DATA")
	MQTT_PORT=$(jq -r '.mqtt.port' <<< "$API_DATA")
	MQTT_USER=$(jq -r '.mqtt.user' <<< "$API_DATA")
	MQTT_PASSWORD=$(jq -r '.mqtt.password' <<< "$API_DATA")
	MQTT_CLIENT_ID=$(jq -r '.mqtt.client_id' <<< "$API_DATA")
	readarray -t TLS_FLAGS < <(jq -r '.mqtt.tls_flags[]' <<< "$API_DATA")
fi

CERT_DIR=/data/letsencrypt
CERT_PATH="${CERT_DIR}/live/$DYNU_HOSTNAME"
CERT_FILE="${CERT_PATH}/cert.pem"
WORK_DIR=/data/workdir
DNS_MULTI_CREDS=/data/dns-multi.ini
ACME_ARGUMENTS=()
KEY_ARGUMENTS=()
ADDITIONAL_ARGS=()
POST_CHECK="false"
LAST_CHECK="ok"
PROPAGATION_SECONDS=300
FIRST_RUN="true"

declare -A MQTT_RETRY_MAP=()

mqtt_publish() {
    if [[ "$USE_MQTT" == "true" ]]; then
        local topic="$1"
        local payload="$2"

        if ! mosquitto_pub \
			--quiet \
            -h "$MQTT_HOST" \
            -p "$MQTT_PORT" \
            -u "$MQTT_USER" \
            -P "$MQTT_PASSWORD" \
			-i "$MQTT_CLIENT_ID" \
            -t "dynu_updater/${topic}" \
            -m "$payload" \
            -r \
			"${TLS_FLAGS[@]}"; then

            bashio::log.warning "Certificate Manager - MQTT publish failed: Topic=${topic}."
			
			# Store only the latest payload for this topic
			MQTT_RETRY_MAP["$topic"]="$payload"
        fi
    fi
}

mkdir -p "${WORK_DIR}"
mkdir -p "${CERT_DIR}"

touch "${DNS_MULTI_CREDS}"
chmod 0600 "${DNS_MULTI_CREDS}"

# Start building the dns-multi credentials file
echo "# generated by letsencrypt app startup script" > "${DNS_MULTI_CREDS}"
echo "dns_multi_provider = dynu" >> "${DNS_MULTI_CREDS}"
echo "DYNU_API_KEY=${DYNU_API_KEY}" >> "${DNS_MULTI_CREDS}"
echo "DYNU_PROPAGATION_TIMEOUT=${PROPAGATION_SECONDS}" >> "${DNS_MULTI_CREDS}"

ACME_ARGUMENTS+=("--authenticator" "dns-multi" "--dns-multi-credentials" "${DNS_MULTI_CREDS}" "--dns-multi-propagation-seconds" "${PROPAGATION_SECONDS}")

# Default Let's Encrypt servers.
ACME_ARGUMENTS+=("--preferred-chain" "ISRG Root X2")

if [[ "$FORCE_RENEW" == "true" ]]; then
	ADDITIONAL_ARGS+=("--force-renewal")
fi

if [[ "$LOG_LEVEL" ==  "debug" ]]; then
	ADDITIONAL_ARGS+=("-vvv")
elif [[ "$LOG_LEVEL" ==  "warning" ]]; then
	ADDITIONAL_ARGS+=("-vv")
elif [[ "$LOG_LEVEL" ==  "error" ]]; then
	ADDITIONAL_ARGS+=("-v")
fi

if [[ "$DRY_RUN" == "true" ]]; then
	ADDITIONAL_ARGS+=("--dry-run")
fi

# Set key-type
KEY_ARGUMENTS+=("--key-type" "ecdsa")
KEY_ARGUMENTS+=("--elliptic-curve" "secp256r1")

check_connectivity() {
    # Try Dynu (IPv4 or IPv6)
    if curl -4 -s --fail --max-time 5 https://checkip.dynu.com >/dev/null \
	  || curl -6 -s --fail --max-time 5 https://checkip.dynu.com >/dev/null; then
        return 0
    fi

    return 1
}

renew_cert() {
	sleep infinity
	POST_CHECK="true"
	until check_connectivity; do
        bashio::log.warning "Certificate Manager - Dynu not reachable, delaying certificate renewal."
        sleep 60
    done
	
	set -o pipefail
	
	TMP_OUTPUT=$(mktemp)

	if certbot certonly --non-interactive --keep-until-expiring --expand \
		  --email "${EMAIL}" --agree-tos \
		  "${KEY_ARGUMENTS[@]}" \
		  "${ADDITIONAL_ARGS[@]}" \
		  --cert-name "${DYNU_HOSTNAME}" "${DOMAIN_ARR[@]/#/-d }" \
		  --config-dir "${CERT_DIR}" --work-dir "${WORK_DIR}" \
		  --preferred-challenges dns \
		  "${ACME_ARGUMENTS[@]}" \
		  2>&1 | tee "$TMP_OUTPUT"; then
		CERTBOT_EXIT=0
	else
		CERTBOT_EXIT=$?
	fi
	
	# If certbot failed
	if [[ "$CERTBOT_EXIT" -ne 0 ]]; then
		bashio::log.error "Certificate Manager - Certbot failed with code ${CERTBOT_EXIT}."
		LAST_CHECK="error"
	else
		# If certbot succeeded, check if certificate was updated
		# Load output into a variable
		CERTBOT_OUTPUT=$(< "$TMP_OUTPUT")
		
		if echo "$CERTBOT_OUTPUT" | grep -q "Successfully received certificate"; then
			bashio::log.info "Certificate Manager - New certificate received."
			
			# Copy the cert and private key to store
			cp "${CERT_PATH}/privkey.pem" "/ssl/$KEYFILE"
			cp "${CERT_PATH}/fullchain.pem" "/ssl/$CERTFILE"
			bashio::log.info "Certificate Manager - New certificates copied to /ssl."
		elif echo "$CERTBOT_OUTPUT" | grep -q "Certificate not yet due for renewal"; then
			bashio::log.info "Certificate Manager - Current certificate is valid."
		elif [[ "$DRY_RUN" == "true" ]] && echo "$CERTBOT_OUTPUT" | grep -q "The dry run was successful"; then	
			bashio::log.info "Certificate Manager - The dry-run was successful."
		else
			bashio::log.warning "Certificate Manager - Unexpected Certbot output"
		fi
	fi
}

check_cert_dates() {
    POST_CHECK="false"
	LAST_CHECK="ok"

	if [[ "$FIRST_RUN" == "true" && "$FORCE_RENEW" == "true" ]]; then
		bashio::log.info "Certificate Manager - Skipping certificate date check: Force Renew."
        mqtt_publish "last_cert_status" "false"
        renew_cert
	elif [[ "$FIRST_RUN" == "true" && "$DRY_RUN" == "true" ]]; then
		bashio::log.info "Certificate Manager - Skipping certificate date check: Test Run."
        renew_cert
    elif [[ -f "$CERT_FILE" ]]; then
		bashio::log.info "Certificate Manager - Checking certificate dates."
		mqtt_publish "last_cert_check" "$(date -Is)"
        if ! VALID_FROM_RAW=$(openssl x509 -in "${CERT_FILE}" -noout -startdate 2>/dev/null | cut -d= -f2); then
			VALID_FROM_RAW=""
		fi
		if ! CREATED_RAW=$(stat -c %y "${CERT_FILE}"); then
			CREATED_RAW=""
		fi
		if ! EXPIRY_RAW=$(openssl x509 -in "${CERT_FILE}" -noout -enddate 2>/dev/null | cut -d= -f2); then
			EXPIRY_RAW=""
		fi
		bashio::log.debug "Certificate Manager - Checking Certificate Domains."
		if ! readarray -t CERT_DOMAINS < <(
				openssl x509 -in "$CERT_FILE" -noout -text \
				| awk '/Subject Alternative Name/{getline; print}' \
				| sed 's/DNS://g' \
				| tr ',' '\n' \
				| sed 's/^[[:space:]]*//; s/[[:space:]]*$//' \
				| sed '/^$/d'
			); then
			
			bashio::log.debug "Certificate Manager - Checking Certificate Domains failed."
			CERT_DOMAINS=()
		fi
		
		if [[ "$LOG_LEVEL" == "debug" ]]; then
			for CERT_DOMAIN in "${CERT_DOMAINS[@]}"; do
				bashio::log.debug "    - ${CERT_DOMAIN}."
			done
		fi
		
		
        # If parsing fails, force renewal
        if [[ -n "$VALID_FROM_RAW" && -n "$CREATED_RAW" && -n "$EXPIRY_RAW" && "${#CERT_DOMAINS[@]}" -ne 0 ]]; then
			VALID_FROM_ISO=$(date -u -d "${VALID_FROM_RAW}" +"%Y-%m-%dT%H:%M:%S+00:00")
			CREATED_ISO=$(date -u -d "${CREATED_RAW}" +"%Y-%m-%dT%H:%M:%S+00:00")
			EXPIRY_ISO=$(date -u -d "${EXPIRY_RAW}" +"%Y-%m-%dT%H:%M:%S+00:00")

            mqtt_publish "cert_expires" "$EXPIRY_ISO"
            mqtt_publish "cert_created" "$CREATED_ISO"

            EXPIRY_EPOCH=$(date -d "${EXPIRY_RAW}" +%s)
            NOW_EPOCH=$(date +%s)
            MAX_EPOCH=$(( NOW_EPOCH + (CHECK_DAYS * 86400) + 60 ))
			
			bashio::log.info "Certificate Manager - Certificate created ${CREATED_ISO}."
			bashio::log.info "Certificate Manager - Certificate valid from ${VALID_FROM_ISO}."
			bashio::log.info "Certificate Manager - Certificate expires ${EXPIRY_ISO}."
			
			ALL_VALID="true"
			
			DOMAIN_COUNT="${#DOMAIN_ARR[@]}"
			CERT_COUNT="${#CERT_DOMAINS[@]}"
			
			bashio::log.debug "Certificate Manager - Domain Count: ${DOMAIN_COUNT}"
			bashio::log.debug "Certificate Manager - Cert Count: ${CERT_COUNT}"

			if [[ "$DOMAIN_COUNT" == "$CERT_COUNT" ]]; then
			
				for DOMAIN in "${DOMAIN_ARR[@]}"; do
					MATCHED="false"
					for CERT_DOMAIN in "${CERT_DOMAINS[@]}"; do
						if [[ "$DOMAIN" == "$CERT_DOMAIN" ]]; then
							MATCHED="true"
							break
						fi
					done
					if [[ "$MATCHED" == "false" ]]; then
						ALL_VALID="false"
						bashio::log.debug "Certificate Manager - Domain ${DOMAIN} not found in Certificate"
						break
					fi
				done
				
				if [[ "$ALL_VALID" == "true" ]]; then
					for CERT_DOMAIN in "${CERT_DOMAINS[@]}"; do
						MATCHED="false"
						for DOMAIN in "${DOMAIN_ARR[@]}"; do
							if [[ "$DOMAIN" == "$CERT_DOMAIN" ]]; then
								MATCHED="true"
								break
							fi
						done
						if [[ "$MATCHED" == "false" ]]; then
							ALL_VALID="false"
							bashio::log.debug "Certificate Manager - Cert Domain ${CERT_DOMAIN} not found in Domain List"
							break
						fi
					done
				fi
			else
				ALL_VALID="false"
			fi
			
			if [[ "$ALL_VALID" == "false" ]]; then
				bashio::log.info "Certificate Manager - Hostnames do not match, renewing."
				mqtt_publish "last_cert_status" "false"
                renew_cert
            elif (( NOW_EPOCH >= EXPIRY_EPOCH )); then
                bashio::log.info "Certificate Manager - Certificate expired, renewing."
				mqtt_publish "last_cert_status" "false"
                renew_cert
            elif (( MAX_EPOCH >= EXPIRY_EPOCH )); then
				bashio::log.info "Certificate Manager - Certificate expires in less than ${CHECK_DAYS} days, renewing."
                mqtt_publish "last_cert_status" "true"
                renew_cert
            else
				bashio::log.info "Certificate Manager - Certificate does not require renewing."
                NEXT_CHECK=$(( EXPIRY_EPOCH - (CHECK_DAYS * 86400) ))
				if (( NOW_EPOCH >= NEXT_CHECK )); then
					NEXT_CHECK=$(( NOW_EPOCH + 600 ))
				fi
				mqtt_publish "last_cert_status" "true"
            fi
		else
			bashio::log.warning "Certificate Manager - Unable to parse certificate data."
            mqtt_publish "last_cert_status" "false"
            renew_cert
        fi
    else
        bashio::log.warning "Certificate Manager - Certificate missing/not yet created."
        mqtt_publish "last_cert_status" "false"
        renew_cert
    fi

    # Post-renewal verification
    if [[ "$POST_CHECK" == "true" ]]; then
        NOW_EPOCH=$(date +%s)
		if [[ "$LAST_CHECK" == "error" ]]; then
			bashio::log.warning "Certificate Manager - Last renewal failed. Retrying in 10 minutes."
			NEXT_CHECK=$(( NOW_EPOCH + 600 ))
		elif [[ -f "$CERT_FILE" ]]; then
			if ! VALID_FROM_RAW=$(openssl x509 -in "${CERT_FILE}" -noout -startdate 2>/dev/null | cut -d= -f2); then
				VALID_FROM_RAW=""
			fi
			if ! CREATED_RAW=$(stat -c %y "${CERT_FILE}"); then
				CREATED_RAW=""
			fi
			if ! EXPIRY_RAW=$(openssl x509 -in "${CERT_FILE}" -noout -enddate 2>/dev/null | cut -d= -f2); then
				EXPIRY_RAW=""
			fi

            if [[ -n "$VALID_FROM_RAW" && -n "$CREATED_RAW" && -n "$EXPIRY_RAW" ]]; then
				VALID_FROM_ISO=$(date -u -d "${VALID_FROM_RAW}" +"%Y-%m-%dT%H:%M:%S+00:00")
				CREATED_ISO=$(date -u -d "${CREATED_RAW}" +"%Y-%m-%dT%H:%M:%S+00:00")
				EXPIRY_ISO=$(date -u -d "${EXPIRY_RAW}" +"%Y-%m-%dT%H:%M:%S+00:00")

				mqtt_publish "cert_expires" "$EXPIRY_ISO"
				mqtt_publish "cert_created" "$CREATED_ISO"

                EXPIRY_EPOCH=$(date -d "${EXPIRY_RAW}" +%s)

                if (( NOW_EPOCH >= EXPIRY_EPOCH )); then
                    mqtt_publish "last_cert_status" "false"
					NEXT_CHECK=$(( NOW_EPOCH + 600 ))
					
				else
					NEXT_CHECK=$(( EXPIRY_EPOCH - (CHECK_DAYS * 86400) ))
					if (( NOW_EPOCH >= NEXT_CHECK )); then
						NEXT_CHECK=$(( NOW_EPOCH + 600 ))
					fi
					mqtt_publish "last_cert_status" "true"
				fi
            else
                bashio::log.warning "Certificate Manager - Unable to parse renewed certificate dates. Recheking in 10 minutes"
                mqtt_publish "last_cert_status" "false"
				NEXT_CHECK=$(( NOW_EPOCH + 600 ))
            fi
        else
            bashio::log.warning "Certificate Manager - Certificate missing/not created after renewal. Check the logs for more information. Recheking in 10 minutes"
            mqtt_publish "last_cert_status" "false"
			NEXT_CHECK=$(( NOW_EPOCH + 600 ))
        fi
    fi
}

NEXT_CHECK=$(date +%s)

while true; do
	if [[ ${#MQTT_RETRY_MAP[@]} -ne 0 ]]; then
		for topic in "${!MQTT_RETRY_MAP[@]}"; do
            payload="${MQTT_RETRY_MAP[$topic]}"

            if mosquitto_pub \
				--quiet \
                -h "$MQTT_HOST" \
                -p "$MQTT_PORT" \
                -u "$MQTT_USER" \
                -P "$MQTT_PASSWORD" \
                -i "$MQTT_CLIENT_ID" \
                -t "dynu_updater/${topic}" \
                -m "$payload" \
                -r \
                "${TLS_FLAGS[@]}"; then

                bashio::log.info "Certificate Manager - Resent MQTT message: ${topic}"
                unset MQTT_RETRY_MAP["$topic"]
            fi
        done
	fi

	NOW_EPOCH=$(date +%s)
	
	if (( NOW_EPOCH >= NEXT_CHECK )); then
		check_cert_dates
	
		NEXT_RUN_ISO=$(date -u -d "@$NEXT_CHECK" +"%Y-%m-%dT%H:%M:%S+00:00")
		bashio::log.info "Certificate Manager - Next renewal check: ${NEXT_RUN_ISO}."
		mqtt_publish "next_cert_check" "$NEXT_RUN_ISO"
		FIRST_RUN="false"
	fi
	
	sleep 1
done

