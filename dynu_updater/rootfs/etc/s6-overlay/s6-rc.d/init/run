#!/usr/bin/with-contenv bashio
# vim: ft=bash
# shellcheck shell=bash
# ==============================================================================
# Init
# ==============================================================================
CERT_DIR=/data/letsencrypt
WORK_DIR=/data/workdir
DNS_API_KEY=/data/dnsapikey
DNS_MULTI_CREDS=/data/dns-multi.ini
ACME_ARGUMENTS=()
KEY_ARGUMENTS=()
ADDITIONAL_ARGS=()

bashio::log.info "Dynu Updater Initialisation - Generating service configuration"

if bashio::config.has_value 'dynu_hostname'; then
	DYNU_HOSTNAME=$(bashio::config 'dynu_hostname' | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')
else
	DYNU_HOSTNAME=""
fi
if bashio::config.has_value 'email'; then
	EMAIL=$(bashio::config 'email' | xargs)
else
	EMAIL=""
fi
if bashio::config.has_value 'domains'; then
	CERT_DOMAINS=$(bashio::config 'domains' | tr '[:upper:]' '[:lower:]' | xargs)
else
	CERT_DOMAINS=""
fi
if bashio::config.has_value 'ip_domains'; then
	IP_DOMAINS=$(bashio::config 'ip_domains' | tr '[:upper:]' '[:lower:]' | xargs)
else
	IP_DOMAINS=""
fi
if bashio::config.true 'verbose'; then
    VERBOSE="true"
else
    VERBOSE="false"
fi
if bashio::config.true 'force_renew'; then
    FORCE_RENEW="true"
else
    FORCE_RENEW="false"
fi
if bashio::config.true 'dry_run'; then
    DRY_RUN="true"
else
    DRY_RUN="false"
fi
if bashio::config.has_value 'dynu_api_key'; then
	DYNU_API_KEY=$(bashio::config 'dynu_api_key' | xargs)
else
	DYNU_API_KEY=""
fi
if bashio::config.has_value 'dynu_update_password'; then
	PASSWORD=$(bashio::config 'dynu_update_password' | xargs)
else
	PASSWORD=""
fi
if bashio::config.has_value 'keyfile'; then
	KEYFILE=$(bashio::config 'keyfile' | xargs)
else
	KEYFILE="privkey.pem"
fi
if bashio::config.has_value 'certfile'; then
	CERTFILE=$(bashio::config 'certfile' | xargs)
else
	CERTFILE="fullchain.pem"
fi
if bashio::config.has_value 'update_cert_time'; then
	CERT_TIME=$(bashio::config 'update_cert_time' | xargs)
else
	CERT_TIME="00:00"
fi
if bashio::config.true 'update_cert'; then
    CERT_VALID="true"
else
    CERT_VALID="false"
fi
if bashio::config.true 'update_ip'; then
    DNS_VALID="true"
else
    DNS_VALID="false"
fi

PROPAGATION_SECONDS=180

# MQTT connection

MQTT_HOST=""
MQTT_USER=""
MQTT_PASSWORD=""
MQTT_PORT=""
	
if bashio::config.true 'mqtt'; then
    USE_MQTT="true"
else
    USE_MQTT="false"
fi

if [[ "$USE_MQTT" == "true" ]] \
   && bashio::services.available 'mqtt' \
   && ! bashio::config.has_value 'mqtt_host' \
   && ! bashio::config.has_value 'mqtt_user' \
   && ! bashio::config.has_value 'mqtt_password' \
   && ! bashio::config.has_value 'mqtt_port'; then
		  
	bashio::log.info "Dynu Updater Initialisation - Loading MQTT server from Supervisor"
    MQTT_HOST=$(bashio::services mqtt host)
    MQTT_USER=$(bashio::services mqtt username)
    MQTT_PASSWORD=$(bashio::services mqtt password)
    MQTT_PORT=$(bashio::services mqtt port)
	
elif [[ "$USE_MQTT" == "true" ]] \
   && bashio::config.has_value 'mqtt_host' \
   && bashio::config.has_value 'mqtt_user' \
   && bashio::config.has_value 'mqtt_password' \
   && bashio::config.has_value 'mqtt_port'; then

	bashio::log.info "Dynu Updater Initialisation - Loading MQTT server from configuration"
    MQTT_HOST=$(bashio::config 'mqtt_host')
    MQTT_USER=$(bashio::config 'mqtt_user')
    MQTT_PASSWORD=$(bashio::config 'mqtt_password')
    MQTT_PORT=$(bashio::config 'mqtt_port')
fi

if [[ "$USE_MQTT" == "true" && ( -z "$MQTT_HOST" || -z "$MQTT_USER" || -z "$MQTT_PASSWORD" || -z "$MQTT_PORT" ) ]]; then
	bashio::log.warning "Dynu Updater Initialisation - Invalid configuration for MQTT"
	USE_MQTT="false"
elif [[ "$USE_MQTT" == "true" ]]; then
	TEST_TOPIC="dynu_updater/selftest"
    TEST_PAYLOAD="selftest_$(date +%s)"
	if ! mosquitto_pub \
		-h "$MQTT_HOST" \
		-u "$MQTT_USER" \
		-P "$MQTT_PASSWORD" \
		-p "$MQTT_PORT" \
		-t "$TEST_TOPIC" \
		-m "$TEST_PAYLOAD" \
		-q 1 \
		>/dev/null 2>&1; then
		bashio::log.warning "Dynu Updater Initialisation - Unable to connect to MQTT server"
		USE_MQTT="false"
	else
		bashio::log.info "Dynu Updater Initialisation - MQTT Connected to server $MQTT_HOST"
	fi
fi

if [[ "$CERT_VALID" == "false" && "$DNS_VALID" == "false" ]]; then
	bashio::log.error "Dynu Updater Initialisation - Options to Update IP Addresses and Generate Certificate are both disabled - Nothing to do"
    exit 1
fi

if [[ -z "$DYNU_HOSTNAME" || ! "$DYNU_HOSTNAME" =~ ^[A-Za-z0-9.-]+\.[A-Za-z]{2,}(\.[A-Za-z]{2,})*$ ]]; then
    bashio::log.error "Dynu Updater Initialisation - Invalid Dynu Hostname"
    exit 1
fi

if [[ -z "$DYNU_API_KEY" ]]; then
    bashio::log.error "Dynu Updater Initialisation - Invalid Dynu API Key"
    exit 1
fi

if [[ "$CERT_VALID" == "true" ]]; then
	if [[ -z "$EMAIL" || ! "$EMAIL" =~ ^[^@]+@[^@]+\.[^@]+$ ]]; then
		bashio::log.info "Dynu Updater Initialisation - invalid email address"
		CERT_VALID="false"
	fi

	if [[ -z "$CERT_DOMAINS" ]]; then
		bashio::log.info "Dynu Updater Initialisation - no Certificate Hostnames configured"
		CERT_VALID="false"
	fi

	if [[ -z "$CERTFILE" || ! "$CERTFILE" =~ ^[A-Za-z0-9._/-]+$ ]]; then
		bashio::log.info "Dynu Updater Initialisation - Invalid Certificate File"
		CERT_VALID="false"
	fi

	if [[ -z "$KEYFILE" || ! "$KEYFILE" =~ ^[A-Za-z0-9._/-]+$ ]]; then
		bashio::log.info "Dynu Updater Initialisation - Invalid Private Key File"
		CERT_VALID="false"
	fi
	
	if [[ -z "$CERT_TIME" || ! "$CERT_TIME" =~ ^([01][0-9]|2[0-3]):[0-5][0-9]$ ]]; then
		bashio::log.info "Dynu Updater Initialisation - Invalid Certificate Check Time (00:00 - 23:59)"
		CERT_VALID="false"
	fi
fi

if [[ "$DNS_VALID" == "true" ]]; then
	if [[ -z "$IP_DOMAINS" ]]; then
		bashio::log.info "Dynu Updater Initialisation - no DNS Update Hostnames configured"
		DNS_VALID="false"
	fi

	if [[ -z "$PASSWORD" ]]; then
		bashio::log.info "Dynu Updater Initialisation - no Dynu Account Password configured"
		DNS_VALID="false"
	fi
fi

if [[ "$DNS_VALID" == "false" && "$CERT_VALID" == "false" ]]; then
	bashio::log.error "Dynu Updater Initialisation - No valid configuration for Certificate generation or DNS IP Updates"
	exit 1
fi

# Call Dynu API: capture JSON body AND HTTP status separately
DYNU_API_RESPONSE=$(curl -s --fail --max-time 5 \
    -H "API-Key: $DYNU_API_KEY" \
    -w "\n%{http_code}" \
    "https://api.dynu.com/v2/dns")

CURL_EXIT="$?"

# Did curl itself fail?
if [[ "$CURL_EXIT" -ne 0 ]]; then
    bashio::log.error "Dynu Updater Initialisation - unable to contact Dynu API (network or HTTP error)"
    sleep 10
	exit 1
fi

# Split JSON and HTTP status
HTTP_STATUS=$(tail -n1 <<< "$DYNU_API_RESPONSE")
JSON_BODY=$(sed '$d' <<< "$DYNU_API_RESPONSE")

# Handle HTTP status codes explicitly
case "$HTTP_STATUS" in
    200)
        # OK
        ;;
    401)
        bashio::log.error "Dynu Updater Initialisation - Invalid Dynu API key"
        sleep 10
		exit 1
        ;;
    403)
        bashio::log.error "Dynu Updater Initialisation - Dynu API key does not have permission to access DNS records"
        sleep 10
		exit 1
        ;;
    *)
        bashio::log.error "Dynu Updater Initialisation - Dynu API returned HTTP $HTTP_STATUS"
		sleep 10
        exit 1
        ;;
esac

DYNU_DOMAINS_JSON=$(jq '.' <<< "$JSON_BODY" 2>/dev/null)

if [[ $? -ne 0 ]]; then
    bashio::log.error "Dynu Updater Initialisation - invalid JSON returned for DNS Domains"
    sleep 10
	exit 1
fi

DYNU_DOMAIN_ID=$(echo "$DYNU_DOMAINS_JSON" \
	| jq -r --arg HOST "$DYNU_HOSTNAME" '
		.domains[] | select(.name == $HOST) | .id // empty
	')

if [[ -z "$DYNU_DOMAIN_ID" ]]; then
	bashio::log.error "Dynu Updater Initialisation - '$DYNU_HOSTNAME' not found in Dynu domain list"
	sleep 10
	exit 1
fi

DYNU_RECORDS=$(curl -s --fail --max-time 5 -H "API-Key: $DYNU_API_KEY" \
	"https://api.dynu.com/v2/dns/${DYNU_DOMAIN_ID}/record")

if ! echo "$DYNU_RECORDS" | jq empty 2>/dev/null; then
	bashio::log.error "Dynu Updater Initialisation - failed to retrieve valid DNS records from Dynu API"
	sleep 10
	exit 1
fi

DYNU_IPV6_ENABLED=$(
	echo "$DYNU_DOMAINS_JSON" \
	| jq -r --arg HOST "$DYNU_HOSTNAME" '
		.domains[]
		| select(.name == $HOST)
		| .ipv6
	'
)

DYNU_HOSTNAMES=$(
  jq -r '
    [.dnsRecords[].hostname]
    | unique
    | sort_by( (split(".") | length), . )
    | .[]
  ' <<< "$DYNU_RECORDS"
)

if [[ -z "${DYNU_HOSTNAMES//[[:space:]]/}" ]]; then
    bashio::log.error "Dynu Updater Initialisation - Dynu API returned no valid hostnames"
	sleep 10
	exit 1
fi

if [[ "$DNS_VALID" == "true" ]]; then
	if [[ "$DYNU_IPV6_ENABLED" == "true" ]]; then
		bashio::log.info "Dynu Updater Initialisation - IPv6 updating enabled for $DYNU_HOSTNAME"
	else
		DYNU_IPV6_ENABLED="false"
		bashio::log.info "Dynu Updater Initialisation - IPv6 updating disabled for $DYNU_HOSTNAME"
	fi

	DOMAIN_ARR=()
	for DOMAIN in $IP_DOMAINS; do
		if [[ "$DOMAIN" == "*.$DYNU_HOSTNAME" ]]; then
			if [[ $(wc -w <<< "$IP_DOMAINS") -ne 1 ]]; then
				bashio::log.error "Dynu DDNS updater - Wildcard found, ignoring other DNS Update Hostnames"
			fi
			readarray -t DOMAIN_ARR <<< "$DYNU_HOSTNAMES"
			break
		elif ! echo "$DYNU_HOSTNAMES" | grep -qx "$DOMAIN"; then
			bashio::log.error "Dynu DDNS updater - $DOMAIN is not valid for this account"
			continue
		fi
		DOMAIN_ARR+=("$DOMAIN")
	done
	
	if [[ ${#DOMAIN_ARR[@]} -eq 0 ]]; then
		bashio::log.error "Dynu Updater Initialisation - no valid domains found for DNS Update"
		DNS_VALID="false"
	else
		jq -n \
		  --arg ipv6 "$DYNU_IPV6_ENABLED" \
		  --argjson domains "$(printf '%s\n' "${DOMAIN_ARR[@]}" | jq -R . | jq -s .)" \
		  '{ipv6: $ipv6, domains: $domains}' \
		  > /run/dynu-dns.conf
	fi	
fi

if [[ "$CERT_VALID" == "true" ]]; then
	# Gather all domains into a plaintext file and sense check

	DOMAIN_ARR=()
	for DOMAIN in $CERT_DOMAINS; do
		if [[ "$DOMAIN" == "*.$DYNU_HOSTNAME" ]]; then
			if [[ $(wc -w <<< "$CERT_DOMAINS") -ne 1 ]]; then
				bashio::log.error "Dynu DDNS updater - Wildcard found, ignoring other Certificate Hostnames"
			fi
			DOMAIN_ARR=("$DOMAIN")
			break
		elif ! echo "$DYNU_HOSTNAMES" | grep -qx "$DOMAIN"; then
			bashio::log.error "Dynu Updater Initialisation - Invalid Certificate Hostname: $DOMAIN"
			continue
		fi
		DOMAIN_ARR+=("$DOMAIN")
	done
	
	if [[ ${#DOMAIN_ARR[@]} -eq 0 ]]; then
		bashio::log.error "Dynu Updater Initialisation - no valid domains found for Certificate"
		CERT_VALID="false"
	fi	

	if [[ "$CERT_VALID" == "true" ]]; then
		mkdir -p "${WORK_DIR}"
		mkdir -p "${CERT_DIR}"

		touch "${DNS_API_KEY}"
		chmod 0600 "${DNS_API_KEY}"
		touch "${DNS_MULTI_CREDS}"
		chmod 0600 "${DNS_MULTI_CREDS}"
		
		# Start building the dns-multi credentials file
		echo "# generated by letsencrypt app startup script" > "${DNS_MULTI_CREDS}"
		echo "dns_multi_provider = dynu" >> "${DNS_MULTI_CREDS}"
		echo "DYNU_API_KEY=$(bashio::config 'dynu_api_key')" >> "${DNS_MULTI_CREDS}"
		echo "DYNU_PROPAGATION_TIMEOUT=${PROPAGATION_SECONDS}" >> "${DNS_MULTI_CREDS}"

		ACME_ARGUMENTS+=("--authenticator dns-multi" "--dns-multi-credentials \"${DNS_MULTI_CREDS}\"" "--dns-multi-propagation-seconds ${PROPAGATION_SECONDS}")

		# Default Let's Encrypt servers.
		ACME_ARGUMENTS+=("--preferred-chain \"ISRG Root X1\"")

		if [[ "$FORCE_RENEW" == "true" ]]; then
			ADDITIONAL_ARGS+=("--force-renewal")
		fi

		if [[ "$VERBOSE" ==  "true" ]]; then
			ADDITIONAL_ARGS+=("-vvv")
		fi
		
		if [[ "${DRY_RUN}" = "true" ]]; then
			ADDITIONAL_ARGS+=("--dry-run")
		fi

		# Set key-type
		KEY_ARGUMENTS+=("--key-type ecdsa")

		CERTBOT_CMD_FILE="/run/dynu-run-certbot.sh"

		{
			echo "#!/usr/bin/with-contenv bashio"
			echo "set +e"
			echo ""
			echo "certbot certonly \\"
			echo "  --non-interactive \\"
			echo "  --keep-until-expiring \\"
			echo "  --expand \\"
			echo "  --email \"$EMAIL\" \\"
			echo "  --agree-tos \\"

			for arg in "${KEY_ARGUMENTS[@]}"; do
				echo "  $arg \\"
			done

			for arg in "${ADDITIONAL_ARGS[@]}"; do
				echo "  $arg \\"
			done

			echo "  --cert-name \"$DYNU_HOSTNAME\" \\"

			for d in "${DOMAIN_ARR[@]}"; do
				echo "  -d \"$d\" \\"
			done

			for arg in "${ACME_ARGUMENTS[@]}"; do
				echo "  $arg \\"
			done

			echo "  --config-dir \"$CERT_DIR\" \\"
			echo "  --work-dir \"$WORK_DIR\" \\"
			echo "  --preferred-challenges dns"
			echo ""
			echo "exit \$?"   # return certbot’s exit code to the parent script
		} > "$CERTBOT_CMD_FILE"

		chmod +x "$CERTBOT_CMD_FILE"

	fi
fi

if [[ "$DNS_VALID" == "false" && "$CERT_VALID" == "false" ]]; then
	bashio::log.error "Dynu Updater Initialisation - NO Valid configuration for Certificate generation or DNS IP Updates"
    sleep 10
	exit 1
fi

ENTITIES=(
  "last_ip_check|Last IP Check|timestamp|dynu_updater/last_ip_check|sensor||dns"
  "last_ip_update|Last IP Update|timestamp|dynu_updater/last_ip_update|sensor||dns"
  "current_ipv4|Current IPv4||dynu_updater/current_ipv4|sensor||dns"
  "current_ipv6|Current IPv6||dynu_updater/current_ipv6|sensor||dns"
  "next_cert_check|Next Certificate Check|timestamp|dynu_updater/next_cert_check|sensor||cert"
  "last_cert_check|Last Certificate Check|timestamp|dynu_updater/last_cert_check|sensor||cert"
  "last_cert_status|Certificate Valid|problem|dynu_updater/last_cert_status|binary_sensor|\"payload_on\": \"false\", \"payload_off\": \"true\",|dns"
  "wan_connection|WAN Connection|connectivity|dynu_updater/wan_connection|binary_sensor|\"payload_on\": \"true\", \"payload_off\": \"false\",|dns"
  "cert_expires|Certificate Expires|timestamp|dynu_updater/cert_expires|sensor||dns"
  "last_cert_renewal|Last Certificate Renewal|timestamp|dynu_updater/last_cert_renewal|sensor||dns"
)

# MQTT Device metadata
DEVICE_ID="dynu_updater_$(hostname)"
DEVICE_NAME="Dynu Updater"
MANUFACTURER="TheUkShadow"
MODEL="Dynu Updater Companion Integration"
SW_VERSION=$(bashio::addon.version)

# Shared availability topic
AVAIL_TOPIC="dynu_updater/availability"

publish_discovery() {
	if [[ "$USE_MQTT" == "true" ]]; then
		local entity_id="$1"
		local name="$2"
		local device_class="$3"
		local state_topic="$4"
		local component="$5"
		local extra="$6"

		# Only include device_class if non-empty
		local device_class_json=""
		if [[ -n "$device_class" ]]; then
			device_class_json="\"device_class\": \"${device_class}\","
		fi

		# Per‑entity availability topic
		local entity_avail_topic="dynu_updater/${entity_id}/availability"

		if ! mosquitto_pub -h "$MQTT_HOST" -u "$MQTT_USER" -P "$MQTT_PASSWORD" -p "$MQTT_PORT" -r \
			  -t "homeassistant/${component}/${entity_id}/config" \
			  -m "{
			    \"name\": \"${name}\",
			    \"unique_id\": \"${DEVICE_ID}_${entity_id}\",
			    \"state_topic\": \"${state_topic}\",
			    \"availability\": [
				  { \"topic\": \"${AVAIL_TOPIC}\" },
				  { \"topic\": \"${entity_avail_topic}\" }
			    ],
			    \"payload_available\": \"online\",
			    \"payload_not_available\": \"offline\",
			    ${device_class_json}
			    ${extra}
			    \"device\": {
				  \"identifiers\": [\"${DEVICE_ID}\"],
				  \"name\": \"${DEVICE_NAME}\",
				  \"manufacturer\": \"${MANUFACTURER}\",
				  \"model\": \"${MODEL}\",
				  \"sw_version\": \"${SW_VERSION}\"
			    }
			  }"; then
			
			bashio::log.warning "Dynu Updater Initialisation - MQTT discovery failed for entity $entity_id"
		fi	
	fi
}

mqtt_publish() {
	if [[ "$USE_MQTT" == "true" ]]; then
		local topic="$1"
		local payload="$2"

		if ! mosquitto_pub \
			-h "$MQTT_HOST" \
			-p "$MQTT_PORT" \
			-u "$MQTT_USER" \
			-P "$MQTT_PASSWORD" \
			-t "dynu_updater/$topic" \
			-m "$payload" \
			-r; then

			bashio::log.warning "Dynu Updater Initialisation - MQTT publish failed for topic $topic"
		fi
	fi
}

ENTITY_JSON="["

for entry in "${ENTITIES[@]}"; do
	IFS="|" read -r entity_id name device_class state_topic component extra service <<< "$entry"

	publish_discovery \
		"$entity_id" \
		"$name" \
		"$device_class" \
		"$state_topic" \
		"$component" \
		"$extra"

	# Publish initial per‑entity availability
	STATE="online"
	if [[ "$service" == "dns"  && "$DNS_VALID"  == "false" ]] ||
	   [[ "$service" == "cert" && "$CERT_VALID" == "false" ]]; then
		STATE="offline"
	fi
	
	entity_avail="${entity_id}/availability"
	
	mqtt_publish "${entity_avail}" "$STATE"
	
	ENTITY_JSON+="
	  {
		\"entity_id\": \"${entity_id}\",
		\"state_topic\": \"${state_topic}\",
		\"availability_topic\": \"${entity_avail}\",
		\"component\": \"${component}\",
		\"service\": \"${service}\"
	  },"
done

ENTITY_JSON="${ENTITY_JSON%,}"
ENTITY_JSON+="]"

jq -n \
  --arg mqtt "$USE_MQTT" \
  --arg host "$MQTT_HOST" \
  --arg port "$MQTT_PORT" \
  --arg user "$MQTT_USER" \
  --arg password "$MQTT_PASSWORD" \
  --argjson entities "$ENTITY_JSON" \
  '{
	  mqtt: $mqtt,
	  host: $host,
	  port: $port,
	  user: $user,
	  password: $password,
	  entities: $entities
   }' \
  > /run/dynu-mqtt.conf
  
mqtt_publish "availability" "online"

bashio::log.info "Dynu Updater Initialisation - Complete"
