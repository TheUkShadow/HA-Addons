#!/command/with-contenv bashio
MQTT_CONF="/run/dynu-mqtt.conf"

if [[ -f "$MQTT_CONF" ]]; then
	USE_MQTT=$(jq -r '.mqtt' "$MQTT_CONF")
	MQTT_HOST=$(jq -r '.host' "$MQTT_CONF")
	MQTT_PORT=$(jq -r '.port' "$MQTT_CONF")
	MQTT_USER=$(jq -r '.user' "$MQTT_CONF")
	MQTT_PASSWORD=$(jq -r '.password' "$MQTT_CONF")

	# Publish offline availability
	if [[ "$USE_MQTT" == "true" ]]; then
		bashio::log.info "Dynu Updater Stopping - Sending offline signal to MQTT"
		mosquitto_pub \
		  -h "$MQTT_HOST" \
		  -u "$MQTT_USER" \
		  -p "$MQTT_PORT" \
		  -P "$MQTT_PASSWORD" \
		  -t "dynu_updater/availability" \
		  -m "offline" \
		  -r
	fi
fi
bashio::log.info "Service init exited"



#/etc/s6-overlay/s6-rc.d/init/finish