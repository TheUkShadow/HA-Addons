#!/command/with-contenv bashio
# vim: ft=bash
# shellcheck shell=bash
# ==============================================================================
# Take down the S6 supervision tree when server fails
# ==============================================================================
# shellcheck disable=SC2155

MQTT_CONF="/run/dynu-mqtt.conf"
USE_MQTT=$(jq -r '.mqtt' "$MQTT_CONF")
MQTT_HOST=$(jq -r '.host' "$MQTT_CONF")
MQTT_PORT=$(jq -r '.port' "$MQTT_CONF")
MQTT_USER=$(jq -r '.user' "$MQTT_CONF")
MQTT_PASSWORD=$(jq -r '.password' "$MQTT_CONF")

# Publish offline availability
if [[ "$USE_MQTT" == "true" ]]; then
	bashio::log.info "Dynu Updater Closing - Sending offline signal to MQTT"
	mosquitto_pub \
		-h "$MQTT_HOST" \
		-u "$MQTT_USER" \
		-p "$MQTT_PORT" \
		-P "$MQTT_PASSWORD" \
		-t "dynu_updater/availability" \
		-m "offline" \
		-r
fi